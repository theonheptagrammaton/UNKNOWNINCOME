# ============================================================================
# UNKNOWNINCOME — Environment template
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Exchange API keys MUST be created WITHOUT withdraw permission (doc §13).
# ============================================================================

# ─── App / runtime ──────────────────────────────────────────────────────────
APP_ENV=development                 # development | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
TZ=UTC                              # storage/compute always UTC; UI shows Europe/Istanbul

# ─── Database (PostgreSQL — application state) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://UNKNOWNINCOME:CHANGE_ME@postgres:5432/UNKNOWNINCOME
POSTGRES_USER=UNKNOWNINCOME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=UNKNOWNINCOME

# ─── Redis (arq queue + cache) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Market data store (Parquet + DuckDB) ────────────────────────────────────
DATA_DIR=/data/parquet             # {market}/{symbol}/{tf}.parquet lives here

# ─── Security ────────────────────────────────────────────────────────────────
# Fernet key for encrypting exchange keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
# Secret for signing session tokens / single-user auth
SECRET_KEY=CHANGE_ME_SECRET_KEY
# Single-user auth credentials
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME

# ─── Binance USDT-M perpetual futures (ccxt) ─────────────────────────────────
# Create keys with TRADE + READ only, withdraw DISABLED, IP whitelist enabled.
BINANCE_API_KEY=CHANGE_ME
BINANCE_API_SECRET=CHANGE_ME
BINANCE_TESTNET=true               # true until promotion gate is passed (Phase 7)

# ─── Liquidation collector (Faz 8 — forward-collect for Faz 11) ──────────────
# !forceOrder@arr websocket → `liquidations` table. This data CANNOT be backfilled,
# so turn it on as early as possible; nothing reads it until Faz 11, it only accrues.
LIQUIDATION_COLLECTOR_ENABLED=false  # worker launches it when true
LIQUIDATION_BATCH_ROWS=500           # flush after N buffered events…
LIQUIDATION_BATCH_SECONDS=5.0        # …or after this many seconds, whichever first

# ─── Telegram (notifications + remote control) ───────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME         # single whitelisted chat ID; commands rejected otherwise

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live
